{
  "name": "kincare",
  "private": true,
  "version": "0.1.0",
  "description": "Kincare — Hospital Patient Portal & Healthcare Interoperability Platform",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20.11.0 <21",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @kincare/db prisma:generate",
    "db:migrate": "pnpm --filter @kincare/db prisma:migrate",
    "db:seed": "pnpm --filter @kincare/db seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "^2.0.6",
    "typescript": "^5.5.4",
    "prettier": "^3.3.3",
    "eslint": "^9.8.0",
    "@types/node": "^20.14.13"
  }
}
