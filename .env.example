# ────────────────────────────────────────────────────
#  KINCARE — Environment Variables (example)
#  Copy to .env and fill in real values for your stack.
# ────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
APP_NAME=Kincare
API_PORT=4000
WEB_PORT=3000
WORKER_PORT=4100
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://kincare:kincare@localhost:5432/kincare?schema=public
SHADOW_DATABASE_URL=postgresql://kincare:kincare@localhost:5432/kincare_shadow?schema=public

# ── Redis / BullMQ ──
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_PREFIX=kincare

# ── Auth ──
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900            # 15 minutes
JWT_REFRESH_TTL=2592000       # 30 days
MFA_ISSUER=Kincare
PASSWORD_PEPPER=change-me-pepper-32+chars

# ── Field-level encryption (AES-256-GCM, base64 32 bytes) ──
PHI_ENCRYPTION_KEY=replace-with-base64-32-byte-key

# ── S3 / Object storage (MinIO compatible) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=kincare
S3_SECRET_KEY=kincare-secret
S3_BUCKET_REPORTS=kincare-reports
S3_BUCKET_DICOM=kincare-dicom
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL=300

# ── Orthanc (DICOM) ──
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=orthanc

# ── HL7 v2 MLLP listener ──
HL7_MLLP_ENABLED=false
HL7_MLLP_PORT=2575

# ── Notifications ──
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Kincare <no-reply@kincare.health>"
SMS_PROVIDER=stub        # twilio | termii | stub
SMS_API_KEY=
SMS_FROM=Kincare

# ── Security ──
COOKIE_DOMAIN=localhost
CSRF_SECRET=change-me-csrf-secret
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_MAX_EMAIL=5
LOGIN_RATE_LIMIT_WINDOW_S=300

# ── PHI encryption keys (versioned) ──
# Active key is the highest version label (lexicographic). Multiple versions
# allow zero-downtime rotation: writes use the active key, reads pick the
# version embedded in each ciphertext. Each value must be base64-encoded 32 bytes.
# PHI_KEYS=v1:<base64>;v2:<base64>
# PHI_ENCRYPTION_KEY=<base64>   # legacy single-key fallback

# ── Audit alerting ──
ALERT_FAILED_LOGIN_THRESHOLD=10
ALERT_FAILED_LOGIN_WINDOW_MIN=5
ALERT_BULK_EXPORT_THRESHOLD=50
ALERT_OFF_HOURS_START=22
ALERT_OFF_HOURS_END=6

# ── Data retention ──
RETENTION_JOBS_ENABLED=true
RETENTION_SOFT_DELETE_DAYS=90
RETENTION_INACTIVE_DAYS=2555

# ── HL7 v2 listener (MLLP) ──
HL7_MLLP_PORT=2575
HL7_MLLP_ENABLED=false

# ── Observability (Phase 4) ──
# Traces are exported via OTLP/HTTP. Point at an OpenTelemetry Collector
# that fans out to Tempo/Jaeger and Loki/Prometheus as appropriate.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAMESPACE=kincare
# OTEL_SERVICE_NAME is set per process (kincare-api / kincare-worker).
# OTEL_DISABLED=true                        # opt-out for local dev
METRICS_ENABLED=true
METRICS_PORT=9100                            # worker process metrics endpoint
# LOKI_URL=http://loki:3100                  # enables direct push via pino-loki (stdout JSON is also kept)
# LOKI_BASIC_AUTH=user:password              # optional, for Grafana Cloud / authenticated Loki
LOG_LEVEL=info

# ── Scale (Phase 5) ──
# Connect apps via PgBouncer (transaction pool mode); use the direct URL only
# for `prisma migrate` / `db push` (session-mode features required).
# DATABASE_URL=postgresql://kincare:kincare@localhost:6432/kincare?pgbouncer=true&connection_limit=1
# DIRECT_DATABASE_URL=postgresql://kincare:kincare@localhost:5432/kincare
# DATABASE_REPLICA_URL=postgresql://readonly:readonly@replica:6432/kincare?pgbouncer=true&connection_limit=1
DEFAULT_TENANT_ID=default
HL7_FLOW_ASYNC=false                         # true = MLLP enqueues a BullMQ flow and returns AA immediately
SMART_ACCESS_TTL_SECONDS=3600
# SMART_REGISTRATION_TOKEN=<long-random>     # required to enable RFC 7591 dynamic client registration
